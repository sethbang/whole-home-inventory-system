# WHIS frontend environment template.
# Copy to frontend/.env for local dev.

# Vite dev-server proxy target. Defaults to the Docker service hostname
# (`https://backend:27182`) when running inside compose. For a local-only dev
# run where the backend is on localhost, override to:
#   VITE_BACKEND_URL=https://localhost:27182
VITE_BACKEND_URL=https://backend:27182
